# =============================================================================
# .env.example
# このファイルをコピーして .env を作成してください。
#   copy .env.example .env
#
# その後、DATABASE_URL の password 部分を
# PostgreSQL インストール時に設定したパスワードに変更してください。
# =============================================================================

# PostgreSQL 接続先
# 「password」の部分をインストール時に設定したパスワードに変更する
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventory_db

# API サーバー設定（基本的に変更不要）
API_HOST=0.0.0.0
API_PORT=8000

# フロントエンド開発サーバーのオリジン（基本的に変更不要）
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# 環境識別
APP_ENV=development

# デバッグログ（本番運用時は false に変更）
DEBUG=true
